# LingoLearn API Configuration
# Copy this file to .env and fill in your values

# API Configuration
API_TOKEN=REPLACE-WITH-YOUR-OWN-LMSTUDIO-API-TOKEN
API_HOST=127.0.0.1
API_PORT=1234
VISION_MODEL_ID=zai-org/glm-4.6v-flash
LLM_MODEL_ID=nvidia/nemotron-3-nano
TTS_MODEL_ID=zai-org/glm-4.6v-flash
DEBUG=false

# JWT encode user sessions
JWT_SECRET_KEY=REPLACE-WITH-YOUR-OWN-JWT-SECRET-KEY

# Database Configuration
DATABASE_URL=sqlite:///./lingolearn.db

# CORS Configuration  
ALLOWED_ORIGINS=*

# Google Authentication (if needed for future features)
GOOGLE_CLIENT_ID=REPLACE-WITH-YOUR-OWN-GOOGLE-CLIENT-ID
GOOGLE_CLIENT_SECRET=REPLACE-WITH-YOUR-OWN-GOOGLE-CLIENT-SECRETE
